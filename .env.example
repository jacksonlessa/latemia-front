# URL base da API NestJS (sem barra final)
# Dev:  http://localhost:3001
# Prod: https://api.latemia.com.br
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# URL canônica do site público — usada em metadataBase, sitemap.xml,
# robots.txt e JSON-LD da landing. Sem barra final.
# Dev:  http://localhost:3000
# Prod: https://latemia.com.br
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Ambiente da aplicação — exibe banner de homologação quando definido como "homolog"
# Valores: homolog | (omitir em produção)
NEXT_PUBLIC_APP_ENV=

# Chave pública da Pagar.me usada na tokenização do cartão direto no browser
# (POST https://api.pagar.me/core/v5/tokens?appId=<chave>).
# Em homolog/dev use `pk_test_…`; em produção, `pk_live_…`.
# Configurar também na Vercel.
NEXT_PUBLIC_PAGARME_PUBLIC_KEY=

# Analytics — só ativos no grupo de rotas (public). Quando ausentes, os
# componentes GA4/Meta Pixel renderizam null e nenhuma requisição externa
# acontece (ideal para Preview/dev).
# GA4: https://support.google.com/analytics/answer/9539598 (formato G-XXXXXXXXXX)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
# Meta Pixel ID (numérico, do Events Manager).
NEXT_PUBLIC_META_PIXEL_ID=

# Número do WhatsApp de suporte (somente dígitos, com DDI — ex.: 5511999999999).
# Usado no link de suporte exibido em telas de token inválido/expirado do fluxo de cancelamento.
NEXT_PUBLIC_SUPPORT_WHATSAPP=

# Basic Auth — protege todo o site antes do go-live público.
# Quando ambas as variáveis estiverem definidas, qualquer acesso exige usuário/senha via HTTP Basic Auth.
# Para abrir o site ao público, basta remover (ou deixar em branco) as duas variáveis na Vercel — sem redeploy de código.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
